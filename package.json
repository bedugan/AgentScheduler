{
  "name": "agent-scheduler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/vscodeExtension.js",
  "bin": {
    "agent-scheduler-worker": "./dist/src/workerCli.js"
  },
  "activationEvents": [
    "onCommand:agentScheduler.newSchedule",
    "onCommand:agentScheduler.openSchedule"
  ],
  "contributes": {
    "commands": [
      {
        "command": "agentScheduler.newSchedule",
        "title": "New Schedule",
        "category": "AgentScheduler"
      },
      {
        "command": "agentScheduler.openSchedule",
        "title": "Open Schedule",
        "category": "AgentScheduler"
      }
    ]
  },
  "extensionKind": [
    "ui"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test \"dist/test/**/*.test.js\""
  },
  "engines": {
    "node": ">=26",
    "vscode": "^1.100.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
